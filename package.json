{
  "name": "aw-app",
  "version": "2.0.0",
  "description": "AW App - macOS desktop app",
  "main": "main.js",
  "author": "AW",
  "license": "MIT",

  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --publish never"
  },

  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3"
  },

  "build": {
    "appId": "com.aw.app",
    "productName": "AW App",

    "files": [
      "**/*"
    ],

    "directories": {
      "output": "dist"
    },

    "mac": {
      "target": "dmg",
      "icon": "icon.icns",
      "category": "public.app-category.productivity"
    },

    "dmg": {
      "title": "AW App Installer",
      "window": {
        "width": 540,
        "height": 380
      }
    },

    "publish": null
  }
}
